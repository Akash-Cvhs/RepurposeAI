# LLM Configuration
LLM_API_KEY=your_api_key_here
DEFAULT_LLM_MODEL=openai/gpt-oss-20b

# Legacy LLM Keys (optional)
OPENAI_API_KEY=your_openai_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Database
DATABASE_URL=postgresql://vhs_user:change_this_password@postgres:5432/vhs_drug_db
POSTGRES_USER=vhs_user
POSTGRES_PASSWORD=change_this_password
POSTGRES_DB=vhs_drug_db

# Redis
REDIS_URL=redis://redis:6379/0

# JWT Authentication
JWT_SECRET_KEY=change-this-to-a-random-secret-key-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=1440

# API Configuration
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
MCP_PORT=8001
ALLOWED_ORIGINS=https://your-frontend.vercel.app,http://localhost:3000

# Rate Limiting
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_PER_HOUR=1000

# Data Sources (Optional - for real integrations)
CLINICALTRIALS_API_KEY=your_clinicaltrials_api_key
PATENTS_API_KEY=your_patents_api_key

# File Storage
REPORTS_DIR=backend/archives/reports
RUNS_INDEX_FILE=backend/archives/runs.json

# Monitoring (Optional)
SENTRY_DSN=
LOG_LEVEL=INFO

# Environment
DEBUG=false
