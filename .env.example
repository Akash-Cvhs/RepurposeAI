# App mode
LLM_PROVIDER=groq
ENABLE_LIVE_APIS=false
ENABLE_ARCHIVE_RUNS=true
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Groq (OpenAI-compatible)
GROQ_API_KEY=
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_MODEL=llama-3.1-8b-instant
GROQ_TIMEOUT_SECONDS=30

# ClinicalTrials.gov
CLINICAL_TRIALS_API_URL=https://clinicaltrials.gov/api/v2/studies
CLINICAL_TRIALS_PAGE_SIZE=20
CLINICAL_TRIALS_TIMEOUT_SECONDS=20

# Tavily web search
TAVILY_API_KEY=
TAVILY_API_URL=https://api.tavily.com/search
TAVILY_TIMEOUT_SECONDS=20
TAVILY_MAX_RESULTS=5

# SerpAPI (Google Patents)
SERPAPI_API_KEY=
SERPAPI_API_URL=https://serpapi.com/search
SERPAPI_ENGINE=google_patents
SERPAPI_TIMEOUT_SECONDS=20
SERPAPI_MAX_RESULTS=10

# Resilient HTTP client
HTTP_MAX_RETRIES=2
HTTP_RETRY_BACKOFF_SECONDS=1
HTTP_CIRCUIT_BREAKER_THRESHOLD=3
HTTP_CIRCUIT_RESET_SECONDS=30
